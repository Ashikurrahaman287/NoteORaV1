# ============================================================
# Noteora – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── Database ────────────────────────────────────────────────
# PostgreSQL connection string.
# Vercel: use a serverless-compatible provider (Neon, Supabase, Railway)
# Replit: DATABASE_URL is wired up automatically — do not override it here
DATABASE_URL=postgresql://user:password@host:5432/noteora

# ─── Clerk Authentication ────────────────────────────────────
# Get these from https://clerk.com → Your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# Frontend Clerk key (must start with VITE_ to be exposed to the browser build)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# Clerk proxy URL — proxies Clerk's Frontend API through your own domain.
# Vercel: https://your-app.vercel.app/api/__clerk
# Replit: https://your-repl.replit.app/api/__clerk
# Leave blank to use Clerk's default CDN endpoint (no custom domain proxy)
VITE_CLERK_PROXY_URL=

# ─── Security ─────────────────────────────────────────────────
# Random 32+ character string used for session signing.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_random_32char_hex_secret

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of origins the API allows.
# Vercel:  https://noteora.vercel.app,https://noteora.com
# Replit:  https://your-repl.replit.app
ALLOWED_ORIGINS=https://noteora.vercel.app

# ─── Node ─────────────────────────────────────────────────────
NODE_ENV=production

# ─── Build-time ───────────────────────────────────────────────
# Base path for the Vite frontend build. "/" when deployed at the root on Vercel.
# In Replit this is set automatically by the artifact routing system — do not set it here.
BASE_PATH=/

# Optional: API server log level (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info
