# ============================================================
# Noteora – Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string.
# On Vercel, use a serverless-compatible provider such as:
#   Neon (neon.tech), Supabase, or Railway.
DATABASE_URL=postgresql://user:password@host:5432/noteora

# ── Clerk Authentication ──────────────────────────────────────
# Get these from your Clerk dashboard (https://dashboard.clerk.com).
# Make sure to add your Vercel deployment domain to Clerk's allowed origins.
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# Exposed to the browser at build-time (Vite). Must match CLERK_PUBLISHABLE_KEY.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# The Clerk Frontend API proxy URL (enables custom-domain auth).
# Set to: https://<your-vercel-domain>/api/__clerk
VITE_CLERK_PROXY_URL=https://your-app.vercel.app/api/__clerk

# ── Server ───────────────────────────────────────────────────
NODE_ENV=production

# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=https://your-app.vercel.app

# Random secret for session signing (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-long-random-string

# ── Optional ─────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
