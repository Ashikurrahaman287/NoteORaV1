# ============================================================
# Noteora – Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env* files to version control.
# See DEPLOYMENT.md for production setup instructions.
# ============================================================

# ─── Database ────────────────────────────────────────────────
# PostgreSQL connection string.
#
# PRODUCTION (Vercel):
#   Use serverless-compatible providers:
#   - Neon (https://neon.tech) - recommended for Vercel
#   - Supabase (https://supabase.com) - use pooling endpoint
#   - Railway (https://railway.app) - includes connection pooling
#
# DEVELOPMENT:
#   Local PostgreSQL: postgresql://user:password@localhost:5432/noteora
#   Vercel Postgres: connect via Vercel dashboard
#
# IMPORTANT: Use connection pooling endpoint for serverless!
#            Example: postgresql://user:password@ep-pool.xxx.postgres.vercel-storage.com:5432/noteora
DATABASE_URL=postgresql://user:password@host:5432/noteora

# ─── Clerk Authentication (https://clerk.com) ────────────────
# Get these from https://clerk.com → Your app → API Keys → Keys
#
# Live keys (production):
#   CLERK_PUBLISHABLE_KEY=pk_live_...
#   CLERK_SECRET_KEY=sk_live_...
#
# Test keys (development):
#   CLERK_PUBLISHABLE_KEY=pk_test_...
#   CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# Frontend Clerk key (must start with VITE_ to be exposed to browser build)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# Clerk proxy URL — proxies Clerk's Frontend API through your domain.
# This enables secure authentication and custom domain support.
#
# PRODUCTION:
#   https://noteora.vercel.app/api/__clerk
#   https://noteora.com/api/__clerk
#
# DEVELOPMENT:
#   https://your-repl.replit.app/api/__clerk
#   Or leave blank to use Clerk's default CDN endpoint (no custom domain proxy)
VITE_CLERK_PROXY_URL=

# ─── Security ─────────────────────────────────────────────────
# Random 32+ character hex string used for session signing.
# CRITICAL: Different secret for each environment.
#
# Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Keep this secret and never share it!
SESSION_SECRET=replace_with_a_random_32char_hex_secret

# ─── CORS (Cross-Origin Resource Sharing) ───────────────────
# Comma-separated list of origins the API allows requests from.
# Whitelist only trusted domains to prevent unauthorized API access.
#
# PRODUCTION (note the https://):
#   ALLOWED_ORIGINS=https://noteora.vercel.app,https://noteora.com,https://www.noteora.com
#
# DEVELOPMENT:
#   ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
#
# Use specific domains, NOT wildcards (*) in production
ALLOWED_ORIGINS=https://noteora.vercel.app

# ─── Node Environment ────────────────────────────────────────
# Vercel automatically sets NODE_ENV=production in production
# For local development:
#   development - enables dev tools, detailed error messages
#   production  - production optimizations, minimal logging
NODE_ENV=production

# ─── Build Configuration ───────────────────────────────────────
# Base path for the Vite frontend build.
# "/" when deployed at the root on Vercel or custom domain
# Automatically set by Replit artifact routing — do not change there
BASE_PATH=/

# ─── Logging ─────────────────────────────────────────────────
# API server log level
# Options: trace | debug | info | warn | error | fatal
#
# PRODUCTION: info (balanced logging)
# DEVELOPMENT: debug (detailed information)
LOG_LEVEL=info

# ─── Analytics & Monitoring (Optional) ──────────────────────
# For integrating with monitoring services:
# SENTRY_DSN=https://your-sentry-key@sentry.io/project-id
# DATADOG_API_KEY=your_datadog_api_key
# NEW_RELIC_LICENSE_KEY=your_new_relic_key

# ─── Feature Flags (Optional) ────────────────────────────────
# Enable/disable features:
# ENABLE_BETA_FEATURES=false
# ENABLE_ANALYTICS=true

